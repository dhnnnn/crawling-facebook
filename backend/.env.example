# ============================================================
# Konfigurasi Multi-Platform Social Media Crawler Backend
# Salin file ini ke .env dan isi dengan kredensial Anda
# ============================================================

# --- Facebook ---
FB_EMAIL=email_facebook_anda@gmail.com
FB_PASSWORD=password_facebook_anda

# --- Instagram ---
IG_USERNAME=username_instagram_anda
IG_PASSWORD=password_instagram_anda

# --- TikTok ---
TT_USERNAME=username_tiktok_anda (nomor hp / email)
TT_PASSWORD=password_tiktok_anda

# --- Browser Settings ---
# Mode headless: true = browser tidak terlihat, false = browser terlihat (berguna untuk debug)
HEADLESS=false

# Delay antar aksi (detik) - lebih besar = lebih aman dari deteksi bot
MIN_DELAY=2
MAX_DELAY=5

# Timeout request (milidetik)
REQUEST_TIMEOUT=30000

# Batas scroll per profil/hashtag
MAX_SCROLL_ATTEMPTS=10

# --- Crawler Settings ---
# Maks post yang dicrawl per request (bisa di-override via API)
MAX_POSTS_DEFAULT=5

# --- Paths ---
# Direktori cookies relatif dari root project (d:\.dev\python\Facebook\)
COOKIES_DIR=../data/cookies
